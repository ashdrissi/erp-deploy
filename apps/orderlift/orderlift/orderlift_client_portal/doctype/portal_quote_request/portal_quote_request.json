{
  "doctype": "DocType",
  "name": "Portal Quote Request",
  "module": "Orderlift Client Portal",
  "custom": 0,
  "track_changes": 1,
  "is_submittable": 0,
  "autoname": "naming_series:",
  "engine": "InnoDB",
  "field_order": [
    "naming_series",
    "customer",
    "customer_group",
    "contact",
    "portal_user",
    "status",
    "currency",
    "submitted_on",
    "reviewed_by",
    "reviewed_on",
    "linked_quotation",
    "request_notes",
    "review_comment",
    "items",
    "total_qty",
    "total_amount"
  ],
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "label": "Series", "options": "PQR-.YYYY.-.#####", "reqd": 1, "default": "PQR-.YYYY.-.#####"},
    {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1},
    {"fieldname": "customer_group", "fieldtype": "Link", "label": "Customer Group", "options": "Customer Group", "reqd": 1},
    {"fieldname": "contact", "fieldtype": "Link", "label": "Contact", "options": "Contact", "reqd": 1},
    {"fieldname": "portal_user", "fieldtype": "Link", "label": "Portal User", "options": "User", "reqd": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nSubmitted\nUnder Review\nApproved\nRejected\nQuotation Created", "default": "Draft", "reqd": 1},
    {"fieldname": "currency", "fieldtype": "Link", "label": "Currency", "options": "Currency"},
    {"fieldname": "submitted_on", "fieldtype": "Datetime", "label": "Submitted On", "read_only": 1},
    {"fieldname": "reviewed_by", "fieldtype": "Link", "label": "Reviewed By", "options": "User", "read_only": 1},
    {"fieldname": "reviewed_on", "fieldtype": "Datetime", "label": "Reviewed On", "read_only": 1},
    {"fieldname": "linked_quotation", "fieldtype": "Link", "label": "Linked Quotation", "options": "Quotation", "read_only": 1},
    {"fieldname": "request_notes", "fieldtype": "Text", "label": "Request Notes"},
    {"fieldname": "review_comment", "fieldtype": "Text", "label": "Review Comment"},
    {"fieldname": "items", "fieldtype": "Table", "label": "Items", "options": "Portal Quote Request Item", "reqd": 1},
    {"fieldname": "total_qty", "fieldtype": "Float", "label": "Total Qty", "read_only": 1},
    {"fieldname": "total_amount", "fieldtype": "Currency", "label": "Total Amount", "read_only": 1}
  ],
  "permissions": [
    {"role": "Orderlift Admin", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Sales Manager", "read": 1, "write": 1, "create": 1},
    {"role": "Orderlift Commercial", "read": 1, "write": 1},
    {"role": "B2B Portal Client", "read": 1}
  ]
}
