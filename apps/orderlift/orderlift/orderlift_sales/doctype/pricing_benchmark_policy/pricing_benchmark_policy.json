        {
            "fieldname": "margin_basis_help_html",
            "fieldtype": "HTML",
            "label": "Margin Basis Help",
            "options": "<div style=\"padding:8px 0 4px;line-height:1.55;\"><p><strong>The margin amount depends on Margin Application Basis.</strong></p><p><strong>Base Price</strong>: <code>margin = base_buy_price * margin%</code></p><p><strong>Loaded Cost</strong>: <code>margin = landed_cost * margin%</code></p><p><strong>Sale Price</strong>: margin is treated as part of final sale price.<br><code>margin = landed_cost * margin% / (1 - margin%)</code></p><p style=\"color:#64748b;\">Pricing Sheet and Selling Pricing Builder calculate the displayed Margin % from the actual margin amount against the same basis, so a configured 10% normally displays as 10%. Total Margin includes margin plus tier and territory modifiers when those modifiers apply. Fallback Margin % uses the same basis selected here.</p></div>"
        },
