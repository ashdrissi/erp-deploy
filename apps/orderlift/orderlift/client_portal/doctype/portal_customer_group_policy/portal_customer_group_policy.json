{
  "doctype": "DocType",
  "name": "Portal Customer Group Policy",
  "module": "Orderlift Client Portal",
  "custom": 0,
  "is_submittable": 0,
  "track_changes": 1,
  "autoname": "field:policy_name",
  "engine": "InnoDB",
  "field_order": [
    "policy_name",
    "business_type",
    "crm_segment",
    "customer_group",
    "enabled",
    "portal_price_list",
    "currency",
    "quote_request_allowed",
    "request_approval_required",
    "welcome_message",
    "catalog_items"
  ],
  "fields": [
    {"fieldname": "policy_name", "fieldtype": "Data", "label": "Policy Name", "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "business_type", "fieldtype": "Link", "label": "Business Type", "options": "CRM Business Type", "in_list_view": 1},
    {"fieldname": "crm_segment", "fieldtype": "Link", "label": "CRM Segment", "options": "CRM Segment", "in_list_view": 1},
    {"fieldname": "customer_group", "fieldtype": "Link", "label": "Legacy Customer Group", "options": "Customer Group", "default": "All Customer Groups", "hidden": 1},
    {"fieldname": "enabled", "fieldtype": "Check", "label": "Enabled", "default": "1"},
    {"fieldname": "portal_price_list", "fieldtype": "Link", "label": "Portal Price List", "options": "Price List", "reqd": 1},
    {"fieldname": "currency", "fieldtype": "Link", "label": "Currency", "options": "Currency"},
    {"fieldname": "quote_request_allowed", "fieldtype": "Check", "label": "Quote Request Allowed", "default": "1"},
    {"fieldname": "request_approval_required", "fieldtype": "Check", "label": "Request Approval Required", "default": "1"},
    {"fieldname": "welcome_message", "fieldtype": "Small Text", "label": "Welcome Message"},
    {"fieldname": "catalog_items", "fieldtype": "Table", "label": "Allowed Products", "options": "Portal Customer Group Product"}
  ],
  "permissions": [
    {"role": "Orderlift Admin", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Sales Manager", "read": 1, "write": 1, "create": 1},
    {"role": "Orderlift Commercial", "read": 1}
  ]
}
